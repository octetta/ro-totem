<!DOCTYPE html>
<html>

<script>

function assign(id, value) {
    const element = document.getElementById(id);
    if (element) {
        element.textContent = value;
    } else {
        console.warn(`Element with ID "${id}" not found.`);
    }
}

</script>

<style>
.row {
    display: flex;          /* Align children horizontally */
    align-items: center;    /* Center them vertically relative to each other */
    gap: 10px;              /* Spacing between button and text */
    margin-bottom: 4px;     /* Spacing between rows */
}

.mono {
    font-family: monospace;
    padding: 4px 8px;
    flex-grow: 1;           /* Optional: Makes the div take up remaining space */
    min-width: 0;           /* Prevents long paths from breaking the layout */
    overflow: hidden;
    text-overflow: ellipsis; /* Adds "..." if the path is too long */
    white-space: nowrap;
}
</style>

<body>
  <h4>all</h4>
  <div class="row">
  <button onclick="window.external.invoke('@')">dir</button>
  <div id="dir" class="mono">{}</div>
  </div>
  <button onclick="window.external.invoke('! v0l1 v1l1 v2l1 v3l1')">all go</button>
  <button onclick="window.external.invoke('! v0l0 v1l0 v2l0 v3l0')">all no</button>
  <button onclick="window.external.invoke('(')">vol++</button>
  <button onclick="window.external.invoke(')')">vol--</button>
  
  <hr>
  
  <h4>v0</h4>
  <div class="row">
  <button onclick="window.external.invoke('>v0')">v0</button>
  <div id="v0" class="mono">{}</div>
  </div>
  <button onclick="window.external.invoke('!v0l1')">start</button>
  <button onclick="window.external.invoke('!v0l0')">stop</button>
  <button onclick="window.external.invoke('+0')">vol++</button>
  <button onclick="window.external.invoke('-0')">vol--</button>
  <button onclick="window.external.invoke('[0')">speed/2</button>
  <button onclick="window.external.invoke(']0')">speed*2</button>
  
  <hr>
  
  <h4>v1</h4>
  <div class="row">
  <button onclick="window.external.invoke('>v1')">v1</button>
  <div id="v1" class="mono">{}</div>
  </div>
  <button onclick="window.external.invoke('!v1l1')">start</button>
  <button onclick="window.external.invoke('!v1l0')">stop</button>
  <button onclick="window.external.invoke('+1')">vol++</button>
  <button onclick="window.external.invoke('-1')">vol--</button>
  <button onclick="window.external.invoke('[1')">speed/2</button>
  <button onclick="window.external.invoke(']1')">speed*2</button>
  
  <hr>
  
  <h4>v2</h4>
  <div class="row">
  <button onclick="window.external.invoke('>v2')">v2</button>
  <div id="v2" class="mono">{}</div>
  </div>
  <button onclick="window.external.invoke('!v2l1')">start</button>
  <button onclick="window.external.invoke('!v2l0')">stop</button>
  <button onclick="window.external.invoke('+2')">vol++</button>
  <button onclick="window.external.invoke('-2')">vol--</button>
  <button onclick="window.external.invoke('[2')">speed/2</button>
  <button onclick="window.external.invoke(']2')">speed*2</button>

  <hr>
  
  <h4>v3</h4>
    <div class="row">
      <button onclick="window.external.invoke('>v3')">v3</button>
      <div id="v3" class="mono">{}</div>
    </div>
    <button onclick="window.external.invoke('!v3l1')">start</button>
    <button onclick="window.external.invoke('!v3l0')">stop</button>
    <button onclick="window.external.invoke('+3')">vol++</button>
    <button onclick="window.external.invoke('-3')">vol--</button>
    <button onclick="window.external.invoke('[3')">speed/2</button>
    <button onclick="window.external.invoke(']3')">speed*2</button>
  
  <hr>
  
  <button id="reload-btn" onclick="location.reload()">reload</button><br>






<!-- -->

    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            padding: 40px;
            background-color: #f0f2f5;
            color: #1c1e21;
        }

        h2 { border-bottom: 2px solid #ddd; padding-bottom: 10px; }

        /* --- STYLING THE COMPONENTS FROM THE OUTSIDE --- */
        
        control-slider {
            /* These properties "pierce" the Shadow DOM or style the host */
            background: white;
            margin-bottom: 20px;
            padding: 15px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            max-width: 400px;
            
            /* Change the slider theme color globally */
            accent-color: #6200ee; 
            font-weight: 500;
        }

        #special-slider {
            /* Specific styling for one instance */
            accent-color: #03dac6;
            border-left: 6px solid #03dac6;
        }

        .button-group {
            margin-top: 20px;
            display: flex;
            gap: 10px;
        }

        button {
            padding: 10px 16px;
            border: none;
            border-radius: 6px;
            background: #6200ee;
            color: white;
            cursor: pointer;
            font-weight: bold;
        }

        button:hover { background: #4b00b5; }
    </style>

    <h2>Device Controls</h2>

    <control-slider 
        id="volume" 
        label="Master Volume" 
        min="-61" 
        max="0" 
        step=".5" 
        value="-20" 
        format="!;V$1;">
    </control-slider>

    <control-slider 
        id="v1-volume" 
        label="V1 Volume" 
        min="-61" 
        max="10" 
        step="1" 
        value="0" 
        format="!;v1a$1;">
    </control-slider>

    <control-slider 
        id="v1-note-slider" 
        label="v1 note" 
        min="0" 
        max="127" 
        step="0.1" 
        value="69" 
        format="!;v1n$1;">
    </control-slider>
    
    <div class="button-group">
        <button onclick="">down octave</button>
        <button onclick="randomizeFreq()">Randomize Frequency</button>
    </div>

    <div class="button-group">
        <button onclick="setToMid()">Set Volume to 50</button>
        <button onclick="randomizeFreq()">Randomize Frequency</button>
    </div>

    <p><em>Check the Browser Console (F12) to see the function calls.</em></p>

    <script>
        // 1. THE WEB COMPONENT DEFINITION
        class ControlSlider extends HTMLElement {
            constructor() {
                super();
                this.attachShadow({ mode: 'open' });
            }

            static get observedAttributes() {
                return ['min', 'max', 'step', 'value', 'label', 'format'];
            }

            // GETTER: Allows reading el.value
            get value() {
                return parseFloat(this.getAttribute('value') || 0);
            }

            // SETTER: Allows setting el.value = x
            set value(val) {
                this.setAttribute('value', val);
                this.updateUI(val);
            }

            connectedCallback() {
                this.render();
            }

            attributeChangedCallback(name, oldVal, newVal) {
                // Update UI if attributes change via JS (like el.setAttribute)
                if (oldVal !== newVal && this.shadowRoot.innerHTML !== "") {
                    this.updateUI(this.getAttribute('value'));
                }
            }

            updateUI(val) {
                const input = this.shadowRoot.querySelector('input');
                const display = this.shadowRoot.querySelector('.display');
                if (input) input.value = val;
                if (display) display.textContent = val;
            }

            render() {
                const min = this.getAttribute('min') || 0;
                const max = this.getAttribute('max') || 100;
                const step = this.getAttribute('step') || 1;
                const val = this.getAttribute('value') || min;
                const label = this.getAttribute('label') || 'Slider';

                this.shadowRoot.innerHTML = `
                <style>
                    :host { display: block; }
                    .wrapper { display: flex; flex-direction: column; gap: 8px; }
                    label { font-size: 0.8rem; color: #666; text-transform: uppercase; }
                    .row { display: flex; align-items: center; gap: 15px; }
                    input { flex-grow: 1; cursor: pointer; }
                    span { 
                        min-width: 50px; 
                        font-family: monospace; 
                        background: #eee; 
                        padding: 4px 8px; 
                        border-radius: 4px; 
                        text-align: center; 
                        font-size: 0.9rem;
                    }
                </style>
                <div class="wrapper">
                    <label>${label}</label>
                    <div class="row">
                        <input type="range" min="${min}" max="${max}" step="${step}" value="${val}">
                        <span class="display">${val}</span>
                    </div>
                </div>
                `;

                // Handle internal input events
                this.shadowRoot.querySelector('input').addEventListener('input', (e) => {
                    const newVal = e.target.value;
                    this.setAttribute('value', newVal); // Keep attribute in sync
                    this.updateUI(newVal);
                    
                    // Dispatch custom event for external listeners
                    <!--
                    this.dispatchEvent(new CustomEvent('update', { 
                        detail: { 
                            value: parseFloat(newVal),
                            formatted: (this.getAttribute('format') || '$1').replace('$1', newVal)
                        } 
                    }));
                    -->
this.dispatchEvent(new CustomEvent('update', { 
    bubbles: true,   // Allows the event to move up the DOM tree
    composed: true,  // Allows the event to cross the Shadow DOM boundary
    detail: { 
        value: parseFloat(newVal),
        formatted: (this.getAttribute('format') || '$1').replace('$1', newVal)
    } 
}));
                });
            }
        }

        // Register the tag
        customElements.define('control-slider', ControlSlider);

        // 2. USING THE COMPONENTS
        const volEl = document.getElementById('volume');
        const freqEl = document.getElementById('special-slider');

        // Example: Listening for the "update" event
        document.addEventListener('update', (e) => {
            //console.log("Target function called with string:", e.detail.formatted);
            console.log(e.detail.formatted);
            window.external.invoke(e.detail.formatted);
        });

        function skode(s) {
            window.external.invoke("!;"+s+";");
        }

        // Example: Using the Helper "Setter"
        function setToMid() {
            volEl.value = -20; 
            window.external.invoke("!;V"+volEl.value+";");
        }

        function randomizeFreq() {
            const min = parseFloat(freqEl.getAttribute('min'));
            const max = parseFloat(freqEl.getAttribute('max'));
            freqEl.value = (Math.random() * (max - min) + min).toFixed(1);
        }
    </script>

<!-- -->

</body></html>

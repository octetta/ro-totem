        .xtra-btn:hover { background: #76D1A4; }

        .wave-btn { color: #fff; background: rgb(98, 0, 238); }
        .wave-btn:hover { background: rgb(141, 65, 244); }

        hr { border: 0; border-top: 1px solid #ddd; margin: 15px 0; }


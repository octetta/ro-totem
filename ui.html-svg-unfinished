    <script>
        function unity(s) {
          var t = s + "-freq";
          var f = document.getElementById(t).value
          f = 69;
          document.getElementById(t).value = f;
          skode(s+"n"+f);
        }
        function double(s) {
          var t = s + "-freq";
          var f = document.getElementById(t).value
          f += 12.0;
          if (f > 127) f = 127;
          document.getElementById(t).value = f;
          skode(s+"n"+f);
        }
        function half(s) {
          var t = s + "-freq";
          var f = document.getElementById(t).value
          f -= 12.0;
          if (f < 0) f = 0;
          document.getElementById(t).value = f;
          skode(s+"n"+f);
        }
        function adder(s) {
          var t = s + "-freq";
          var f = document.getElementById(t).value
          f += 1.0;
          if (f > 127) f = 0;
          document.getElementById(t).value = f;
          skode(s+"n"+f);
        }
        function subber(s) {
          var t = s + "-freq";
          var f = document.getElementById(t).value
          f -= 1.0;
          if (f < 0) f = 0;
          document.getElementById(t).value = f;
          skode(s+"n"+f);
        }
    </script>


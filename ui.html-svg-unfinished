<script>
    // --- CUSTOM ELEMENT DEFINITION ---
    class ControlSlider extends HTMLElement {
        constructor() {
            super();
            this.attachShadow({ mode: 'open' });
        }

        static get observedAttributes() {
            return ['min', 'max', 'step', 'value', 'label', 'format'];
        }

        get value() { return parseFloat(this.getAttribute('value') || 0); }
        set value(val) {
            this.setAttribute('value', val);
            this.updateUI(val);
        }

        connectedCallback() { this.render(); }

        attributeChangedCallback(name, oldVal, newVal) {
            if (oldVal !== newVal && this.shadowRoot.innerHTML !== "") {
                this.updateUI(this.getAttribute('value'));
            }
        }

        updateUI(val) {
            const input = this.shadowRoot.querySelector('input');
            const display = this.shadowRoot.querySelector('.display');
            if (input) input.value = val;
            if (display) display.textContent = val;
        }

        render() {
            const min = this.getAttribute('min') || 0;
            const max = this.getAttribute('max') || 100;
            const step = this.getAttribute('step') || 1;
            const val = this.getAttribute('value') || min;
            const label = this.getAttribute('label') || 'Slider';

            this.shadowRoot.innerHTML = `
            <style>
                .wrapper { display: flex; flex-direction: column; gap: 4px; }
                label { font-size: 0.75rem; color: #666; font-weight: bold; }
                .row { display: flex; align-items: center; gap: 10px; }
                input { flex-grow: 1; accent-color: #6200ee; cursor: pointer; }
                span { font-family: monospace; font-size: 0.85rem; min-width: 45px; text-align: right; }
            </style>
            <div class="wrapper">
                <label>${label}</label>
                <div class="row">
                    <input type="range" min="${min}" max="${max}" step="${step}" value="${val}">
                    <span class="display">${val}</span>
                </div>
            </div>`;

            this.shadowRoot.querySelector('input').addEventListener('input', (e) => {
                const v = e.target.value;
                this.setAttribute('value', v);
                this.updateUI(v);
                this.dispatchEvent(new CustomEvent('update', { 
                    bubbles: true, 
                    composed: true, 
                    detail: { 
                        value: parseFloat(v),
                        formatted: (this.getAttribute('format') || '$1').replace('$1', v)
                    } 
                }));
            });
        }
    }
    customElements.define('control-slider', ControlSlider);

    // --- SYSTEM INTEGRATION ---
    let files = [];
    
    function lclear() {
      files = [];
    }

    let lndx = 600;

    function lstuff(value) {
      files.push(value);
    }
    
    function lrand(v) {
      if (files.length == 0) { return; }
      let r = Math.floor(Math.random() * files.length);
      let f = files[r];
      let d = document.getElementById("dir").textContent;
      let t = `${d}/${f}`;
      let cmd = `{${t}} /ws ${lndx} v${v} w${lndx} a0 B1 f440 t1 0 1 1`;
      console.log(cmd);
      assign(v, f);
      skode(cmd);
      lndx++;
      if (lndx > 999) { lndx = 0; }
    }
    
    function assign(id, value) {
        const element = document.getElementById(id);
        if (element) element.textContent = value;
    }

    document.addEventListener('update', (e) => {
        console.log("Slider Action:", e.detail.formatted);
        if (window.external && window.external.invoke) {
            window.external.invoke(e.detail.formatted);
        }
    });

    function getcmd() {
        return document.getElementById('skode-input').value;
    }

    function skode(s) {
        if (s.length > 0) {
            addLog(s);
            window.external.invoke("!;" + s + ";");
        }
    }

// Get the input element by its ID
